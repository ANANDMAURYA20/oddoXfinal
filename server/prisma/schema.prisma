generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  TRIAL
  BASIC
  PRO
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  CASHIER
  KDS_STAFF
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  SPLIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ─────────────────────────────────────────────
// Multi-Tenant Core
// ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  plan      Plan     @default(TRIAL)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  products    Product[]
  categories  Category[]
  orders      Order[]
  customers   Customer[]
  discounts   Discount[]
  settings         Settings?
  kdsStations      KdsStation[]
  registerSessions RegisterSession[]
  customerSessions CustomerSession[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  kdsStationId String?
  kdsStation   KdsStation? @relation(fields: [kdsStationId], references: [id], onDelete: SetNull)

  orders Order[]
  registerSessions RegisterSession[] @relation("registerSessions")

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// QR Ordering Sessions
// ─────────────────────────────────────────────

model CustomerSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique @default(uuid())
  tableNumber  Int      // Matches POS dine-in table number (1..totalTables)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders Order[] @relation("sessionOrders")

  @@index([tenantId])
  @@index([tableNumber, tenantId])
}

model ProductAddon {
  id        String  @id @default(uuid())
  name      String  // e.g., "Extra Cheese", "Spicy Sauce"
  price     Float   @default(0)
  isActive  Boolean @default(true)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─────────────────────────────────────────────
// Inventory & Catalog
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  costPrice   Float?
  stock       Int      @default(0)
  lowStock    Int      @default(5)
  barcode     String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]
  addons     ProductAddon[]

  // QR ordering display
  vegType    String?  // "veg", "non-veg", "egg"

  @@index([tenantId])
  @@index([barcode])
}

// ─────────────────────────────────────────────
// Orders & Billing
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orders Order[]

  @@index([tenantId])
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique
  subtotal      Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  totalAmount   Float
  status        OrderStatus   @default(COMPLETED)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PAID)
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cashierId String?
  cashier   User?  @relation(fields: [cashierId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // QR ordering / dine-in fields
  tableNumber Int?    // Matches POS dine-in table number

  sessionId String?
  session   CustomerSession? @relation("sessionOrders", fields: [sessionId], references: [id], onDelete: SetNull)

  orderSource String  @default("POS") // "POS" | "QR"

  items OrderItem[]

  @@index([tenantId])
  @@index([createdAt])
  @@index([tableNumber])
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float
  addons   Json?  // Store selected addons as JSON: [{name, price}]
  note     String?
  status   OrderItemStatus @default(PENDING)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// Discounts
// ─────────────────────────────────────────────

model Discount {
  id        String       @id @default(uuid())
  code      String
  type      DiscountType
  value     Float
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([code, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// Tenant Settings
// ─────────────────────────────────────────────

model Settings {
  id           String   @id @default(uuid())
  storeName    String   @default("")
  currency     String   @default("INR")
  taxRate      Float    @default(0)
  taxLabel     String   @default("GST")
  receiptNote  String   @default("Thank you for shopping with us!")

  // Onboarding fields
  paymentMethods String[] @default([])
  upiId          String   @default("")
  totalTables    Int      @default(0)
  onboardingCompleted Boolean @default(false)

  // Bill / Receipt details
  storeAddress  String   @default("")
  storePhone    String   @default("")
  gstNumber     String   @default("")
  fssaiNumber   String   @default("")
  storeLogo     String   @default("") // URL

  // QR Ordering settings
  qrOrderingEnabled Boolean @default(false)
  qrOrderingMode    String  @default("order") // "order" = accept orders, "menu" = view menu only
  restaurantLat     Float?
  restaurantLng     Float?
  geofenceRadius    Int     @default(100) // in meters
  geofenceEnabled   Boolean @default(false)

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// POS Register Sessions (Open/Close Day)
// ─────────────────────────────────────────────

enum RegisterStatus {
  OPEN
  CLOSED
}

model RegisterSession {
  id              String         @id @default(uuid())
  openingCash     Float          @default(0)
  closingCash     Float?
  status          RegisterStatus @default(OPEN)
  openedAt        DateTime       @default(now())
  closedAt        DateTime?
  closingNote     String?

  // Snapshot at close time
  totalCashSales  Float?
  totalCardSales  Float?
  totalUpiSales   Float?
  totalOrders     Int?
  totalRevenue    Float?
  expectedCash    Float?         // openingCash + cashSales
  cashDifference  Float?         // actual closingCash - expectedCash

  cashierId String
  cashier   User   @relation("registerSessions", fields: [cashierId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cashierId])
  @@index([openedAt])
}

// ─────────────────────────────────────────────
// Kitchen Display Stations
// ─────────────────────────────────────────────

model KdsStation {
  id          String   @id @default(uuid())
  name        String
  categoryIds String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  users User[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// OTP & Verification
// ─────────────────────────────────────────────

enum OtpType {
  SIGNUP
  FORGOT_PASSWORD
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
